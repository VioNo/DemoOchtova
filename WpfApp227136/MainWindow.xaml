<Window x:Class="WpfApp227136.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp227136"
        mc:Ignorable="d"
        Title="Восьмерка" Height="450" Width="800" >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Image Source="/Resourses/Восьмерка.ico" Grid.Row="0" HorizontalAlignment="Left"/>
        <Button Content="Домой" Grid.Row="0" HorizontalAlignment="Right" Click="ButtonHome_Click" Margin="0,0,80,0"/>
        <Button Content="Назад" Grid.Row="0" HorizontalAlignment="Right" Click="Button_Click"/>
        <Frame x:Name="Main" NavigationUIVisibility="Hidden" Grid.Row="1"/>
    </Grid>
</Window>
