<Page x:Class="WpfApp227136.Pages.MaterialPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp227136.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Материалы" IsVisibleChanged="Page_IsVisibleChanged">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="МАТЕРИАЛЫ" HorizontalAlignment="Center" FontSize="24"/>
        <TextBlock Grid.Row="0" x:Name="FIOTextBlock" HorizontalAlignment="Right"/>
        <ListBox x:Name="MaterialListBox" 
                 Grid.Row="1" 
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text ="{Binding name_material}"/>
                            <TextBlock>
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0}">
                                        <Binding Path="type_materials.type_material"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>  
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"> 
                            <TextBlock Text ="{Binding kolvo_in_paket}"/>
                            <TextBlock>
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0}">
                                        <Binding Path="ed_izms.ed_izm"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text ="{Binding kolvo_on_sklad, StringFormat=Количество на складе:{0}}"/>
                            <TextBlock Text ="{Binding min_ostatok, StringFormat=Минимальный остаток:{0}}"/>
                            <TextBlock Text ="{Binding price, StringFormat=Цена:{0}}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Min0}" Value="True">
                            <Setter Property="Background" Value="Gray"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
        <StackPanel x:Name="MaterialStackPanel" Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Center" >
            <Button x:Name="AddButton" Content="Добавить материал" Click="AddButton_Click"/>
            <Button x:Name="UpdateButton" Content="Редактировать" Click="UpdateButton_Click"/>
            <Button x:Name="DelButton" Content="Удалить" Click="DelButton_Click"/>
        </StackPanel>
    </Grid>
</Page>
