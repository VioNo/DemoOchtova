<Page x:Class="WpfApp227136.Pages.AddMaterialPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp227136.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddMaterialPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="300"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Grid.Row="0" >
            <StackPanel>
                <TextBlock Text="название материал" Margin="6"/>
                <TextBlock Text="тип материал" Margin="6"/>
                <TextBlock Text="количество в пакете" Margin="6"/>
                <TextBlock Text="единица измерения" Margin="6"/>
                <TextBlock Text="количество на складе" Margin="6,10,6,6"/>
                <TextBlock Text="минимальный остаток" Margin="6"/>
                <TextBlock Text="цена" Margin="6"/>
            </StackPanel>
            <StackPanel>
                <TextBox x:Name="name_materialTextBox" Width="180"/>
                <ComboBox x:Name="type_materialComboBox" DisplayMemberPath="type_material" SelectedItem="{Binding name_material}"/>
                <TextBox x:Name="kolvo_in_paketTextBox"/>
                <ComboBox x:Name="ed_izmComboBox" DisplayMemberPath="ed_izm" SelectedItem="{Binding name_material}"/>
                <TextBox x:Name="kolvo_on_skladTextBox"/>
                <TextBox x:Name="min_ostatokTextBox"/>
                <TextBox x:Name="priceTextBox"/>
            </StackPanel>
        </StackPanel>
        <Button x:Name="SaveButton" Content="сохранить" Click="SaveButton_Click" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Top"/>
    </Grid>
</Page>
